# Copy to .env (loaded automatically if python-dotenv is installed).
# DATABASE_URL=postgresql+psycopg://user:pass@localhost/agentverse
DATABASE_URL=sqlite:///./agentverse.db
GRID_SIZE=20
NUM_AGENTS=100
RANDOM_SEED=42
LOG_LEVEL=INFO

# Tier-2 LLM planning (optional). Pull a model first: ollama pull llama3.2 or ollama pull qwen2.5:3b
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2
